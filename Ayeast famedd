<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>おうち科学思考ゲーム：酵母は何と反応する？</title>
  <style>
    body {
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      line-height: 1.7;
      margin: 0;
      background: #f7f7fb;
      color: #222;
    }
    .wrap {
      max-width: 900px;
      margin: 0 auto;
      padding: 24px;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      margin-bottom: 20px;
    }
    h1, h2 {
      margin-top: 0;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
    }
    label.option {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 12px;
      background: #fafafa;
      cursor: pointer;
    }
    input[type="range"] {
      width: 100%;
    }
    .buttons {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 16px;
    }
    button {
      border: none;
      border-radius: 12px;
      padding: 12px 18px;
      font-size: 16px;
      cursor: pointer;
    }
    .run { background: #1f6feb; color: white; }
    .reset { background: #e5e7eb; color: #222; }
    .result-box {
      border-left: 6px solid #1f6feb;
      background: #f0f6ff;
      padding: 16px;
      border-radius: 12px;
    }
    .big {
      font-size: 1.3rem;
      font-weight: 700;
    }
    .small {
      color: #555;
    }
    .meter {
      height: 20px;
      background: #e5e7eb;
      border-radius: 999px;
      overflow: hidden;
      margin: 12px 0;
    }
    .fill {
      height: 100%;
      width: 0;
      background: linear-gradient(90deg, #93c5fd, #2563eb);
      transition: width 0.4s ease;
    }
    .note {
      font-size: 0.95rem;
      color: #444;
    }
    .footer {
      font-size: 0.9rem;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>おうち科学思考ゲーム：酵母は何と反応する？</h1>
      <p>
        パンづくりをヒントに、<strong>酵母に何を加えると、どんな変化が起きるか</strong>を考えるゲームです。
        実験の前に予想してもいいし、実験のあとに結果とくらべてもOKです。
      </p>
    </div>

    <div class="card">
      <h2>1. 材料をえらぶ</h2>
      <div class="grid">
        <label class="option"><input type="checkbox" id="water"> 水</label>
        <label class="option"><input type="checkbox" id="sugar"> 砂糖</label>
        <label class="option"><input type="checkbox" id="salt"> 塩</label>
        <label class="option"><input type="checkbox" id="flour"> 小麦粉</label>
        <label class="option"><input type="checkbox" id="egg"> 卵</label>
      </div>
    </div>

    <div class="card">
      <h2>2. 温度をきめる</h2>
      <p><strong><span id="tempValue">40</span>℃</strong></p>
      <input type="range" id="temp" min="0" max="60" value="40" />
      <p class="note">ヒント：低すぎても、高すぎても、酵母は元気に働きにくいかもしれません。</p>
    </div>

    <div class="card">
      <h2>3. 予想してから、スタート</h2>
      <div class="buttons">
        <button class="run" onclick="runExperiment()">スタート</button>
        <button class="reset" onclick="resetGame()">リセット</button>
      </div>
    </div>

    <div class="card">
      <h2>結果</h2>
      <div class="result-box">
        <div class="big" id="resultText">ここに結果が出ます</div>
        <div class="meter"><div class="fill" id="fillBar"></div></div>
        <p id="reasonText" class="small">材料と温度をえらんで、スタートを押してください。</p>
      </div>
    </div>

    <div class="card">
      <h2>考えてみよう</h2>
      <ul>
        <li>水がないと、どうして変化しにくいのかな？</li>
        <li>砂糖を入れると、どうして変わるのかな？</li>
        <li>40℃くらいで元気そうなのは、なぜかな？</li>
        <li>塩を入れると、どんな影響があるのかな？</li>
      </ul>
      <p class="footer">※ このゲームは、おうち実験の考え方を遊べるようにした簡易モデルです。実際の酵母のふるまいは、量や時間、材料の種類でも変わります。</p>
    </div>
  </div>

  <script>
    const tempSlider = document.getElementById('temp');
    const tempValue = document.getElementById('tempValue');
    tempSlider.addEventListener('input', () => {
      tempValue.textContent = tempSlider.value;
    });

    function runExperiment() {
      const water = document.getElementById('water').checked;
      const sugar = document.getElementById('sugar').checked;
      const salt = document.getElementById('salt').checked;
      const flour = document.getElementById('flour').checked;
      const egg = document.getElementById('egg').checked;
      const temp = Number(document.getElementById('temp').value);

      let score = 0;
      let reasons = [];

      if (!water) {
        score = 0;
        reasons.push('水がないので、酵母が働きにくい。');
      } else {
        score += 25;
        reasons.push('水があるので、酵母が働ける条件に近づいた。');

        if (sugar) {
          score += 35;
          reasons.push('砂糖があるので、酵母の反応が進みやすい。');
        } else {
          reasons.push('砂糖がないので、反応は強くなりにくい。');
        }

        if (temp >= 35 && temp <= 42) {
          score += 30;
          reasons.push('温度がちょうどよく、酵母が元気に働きやすい。');
        } else if ((temp >= 20 && temp < 35) || (temp > 42 && temp <= 50)) {
          score += 10;
          reasons.push('温度は悪くないけれど、ベストではない。');
        } else {
          reasons.push('温度が低すぎるか高すぎて、酵母が働きにくい。');
        }

        if (salt) {
          score -= 20;
          reasons.push('塩があるので、酵母の働きが弱まりやすい。');
        }

        if (flour) {
          score += 5;
          reasons.push('小麦粉があると、パンづくりらしい条件に近づく。');
        }

        if (egg) {
          reasons.push('卵はパンづくりには使うことがあるけれど、酵母の反応そのものを強める主役ではなさそう。');
        }
      }

      if (score < 0) score = 0;
      if (score > 100) score = 100;

      let resultText = '';
      if (score === 0) {
        resultText = '変化なし';
      } else if (score <= 30) {
        resultText = 'すこしだけ変化';
      } else if (score <= 70) {
        resultText = 'ちょっとふくらむ';
      } else {
        resultText = 'よくふくらむ！';
      }

      document.getElementById('resultText').textContent = resultText;
      document.getElementById('reasonText').textContent = reasons.join(' ');
      document.getElementById('fillBar').style.width = score + '%';
    }

    function resetGame() {
      document.getElementById('water').checked = false;
      document.getElementById('sugar').checked = false;
      document.getElementById('salt').checked = false;
      document.getElementById('flour').checked = false;
      document.getElementById('egg').checked = false;
      document.getElementById('temp').value = 40;
      document.getElementById('tempValue').textContent = 40;
      document.getElementById('resultText').textContent = 'ここに結果が出ます';
      document.getElementById('reasonText').textContent = '材料と温度をえらんで、スタートを押してください。';
      document.getElementById('fillBar').style.width = '0%';
    }
  </script>
</body>
</html>
